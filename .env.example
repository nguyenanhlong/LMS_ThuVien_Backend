APP_NAME="LMS ThuVien API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Nếu muốn dùng MySQL, đổi thành:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lms_thuvien
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# Cấu hình Gmail SMTP để gửi email xác nhận đặt trước sách
# Yêu cầu: Tài khoản Gmail phải bật 2-Step Verification, MAIL_PASSWORD là Google App Password 16 ký tự (không phải mật khẩu Gmail thường)
# Cách tạo App Password: https://support.google.com/accounts/answer/185833
# Không commit file .env (chứa thông tin thật) lên GitHub
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_project_gmail@gmail.com
MAIL_PASSWORD=your_google_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_project_gmail@gmail.com
MAIL_FROM_NAME="LMS ThuVien"


